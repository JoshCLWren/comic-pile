{
  "type": "module",
  "name": "comic-pile",
  "version": "0.1.0",
  "description": "Dice-Driven Comic Reading Tracker - FastAPI + HTMX + Tailwind CSS",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "htmlhint": "^1.1.5",
    "jiti": "^2.6.1"
  },
  "scripts": {
    "lint:js": "bash scripts/lint-js.sh",
    "lint:html": "npx htmlhint app/templates/*.html",
    "lint": "npm run lint:js && npm run lint:html",
    "lint:fix": "bash scripts/lint-js.sh --fix",
    "dice:playground": "npm --prefix frontend run dice:playground",
    "test:dice-playground": "npm --prefix frontend run test:dice-playground",
    "test:dice-playground:update": "npm --prefix frontend run test:dice-playground:update",
    "test:e2e:prod-smoke": "npm --prefix frontend run test:e2e:prod-smoke"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jiti": "^2.6.1"
  }
}
